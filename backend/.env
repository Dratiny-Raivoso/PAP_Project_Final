# Liga ao MongoDB local:
MONGO_URI=mongodb://localhost:27017/led_app

# Ou se usares MongoDB Atlas (cloud), substitui pela tua string:
# MONGO_URI=mongodb+srv://utilizador:password@cluster.mongodb.net/led_app

# Chave secreta para assinar os tokens JWT
# Muda isto para uma string longa e aleatória!
JWT_SECRET=led_chave_super_secreta_2024_xyz

# Porta do servidor
PORT=3000